generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  projects Project[]
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  language    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  reviews      Review[]
  projectScans ProjectScan[]
}

model Review {
  id           Int      @id @default(autoincrement())
  overallScore Int?
  summary      String?
  aiReview     String?
  eslintReport String?
  createdAt    DateTime @default(now())

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  findings Finding[]
}

model Finding {
  id           Int    @id @default(autoincrement())
  severity     String
  issue        String
  suggestedFix String
  line         Int?

  reviewId Int
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model ProjectScan {
  id Int @id @default(autoincrement())

  folderName String

  totalFiles    Int
  analyzedFiles Int
  failedFiles   Int

  totalErrors   Int
  totalWarnings Int

  overallScore Int?

  languageSummary Json
  aiReview        Json?
  aiError         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  files ProjectScanFile[]
}

model ProjectScanFile {
  id Int @id @default(autoincrement())

  fileName String
  language String
  status   String

  errorCount   Int
  warningCount Int

  staticAnalysis Json

  analysisError String?

  createdAt DateTime @default(now())

  scanId Int
  scan   ProjectScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
}
